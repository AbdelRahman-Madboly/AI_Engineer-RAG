projects/02_Information_Retrieval_and_Search_Foundations/labs/dataset/

# ── Computed embedding caches ─────────────────────────────────────────────────
# These are generated on first run - no need to track in git
# lab03 saves doc_embeddings.joblib
# lab05 saves embeddings.joblib
projects/02_Information_Retrieval_and_Search_Foundations/labs/*.joblib

# Keep the assignment embeddings (small, pre-computed, required to run)
!projects/01_RAG_Overview/assignments/embeddings.joblib

